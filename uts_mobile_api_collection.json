								"key": "Authorization",
								"value": "Bearer {{anon_key}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/rest/v1/users?username=eq.budi&password=eq.123456&select=*",
							"host": ["{{base_url}}"],
							"path": ["rest", "v1", "users"],
							"query": [
								{
									"key": "username",
									"value": "eq.budi",
									"description": "Username pengguna"
								},
								{
									"key": "password",
									"value": "eq.123456",
									"description": "Password pengguna"
								},
